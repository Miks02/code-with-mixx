<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CodeWithMixx | @ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>
    <link rel="stylesheet" href="~/css/output.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="icon" type="image/png" href="~/codewithmixx-logo-transparent-icon.png"/>
</head>
<body class="min-h-screen flex bg-linear-to-br from-emerald-700 to-emerald-800">

@await Html.PartialAsync("_Partials/Dashboard/_AdminSidebar")

<div class="flex flex-col grow">
    @await Html.PartialAsync("_Partials/Dashboard/_AdminHeader")
    
    <main class="grow p-6">
        @RenderBody()
    </main>
</div>


<script src="https://unpkg.com/htmx.org@2.0.0" defer></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>




