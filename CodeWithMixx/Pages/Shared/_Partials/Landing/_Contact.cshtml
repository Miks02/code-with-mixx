
<section id="contact" class="py-12 bg-linear-to-tr from-emerald-950/80 to-emerald-900">
    <div class="max-w-7xl mx-auto px-8">
        <div class="text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Kontaktiraj me</h2>
            <p class="text-xl text-emerald-100/80 max-w-2xl mx-auto">
                Imaš pitanje ili želiš da zakažeš čas? Pošalji poruku i javiću ti se u najkraćem roku.
            </p>
        </div>

        <div class="flex flex-col-reverse lg:flex-row gap-12">
            <div class="lg:w-1/3 space-y-8">
                <div class="flex items-center gap-6 group">
                    <div class="w-14 h-14 bg-emerald-800 backdrop-blur-md rounded-2xl flex items-center justify-center text-amber-500 text-2xl transition duration-200 group-hover:scale-110 shadow-lg">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div>
                        <p class="text-emerald-100/40 text-xs uppercase font-bold tracking-wider italic">Email adresa</p>
                        <p class="text-white font-semibold">milan@codewithmixx.com</p>
                    </div>
                </div>

                <div class="flex items-center gap-6 group">
                    <div class="w-14 h-14 bg-emerald-800 backdrop-blur-md rounded-2xl flex items-center justify-center text-amber-500 text-2xl transition duration-200 group-hover:scale-110 shadow-lg">
                        <i class="fab fa-discord"></i>
                    </div>
                    <div>
                        <p class="text-emerald-100/40 text-xs uppercase font-bold tracking-wider italic">Discord</p>
                        <p class="text-white font-semibold">mixx002</p>
                    </div>
                </div>

                <div class="flex items-center gap-6 group">
                    <div class="w-14 h-14 bg-emerald-800 backdrop-blur-md rounded-2xl flex items-center justify-center text-amber-500 text-2xl transition duration-200 group-hover:scale-110 shadow-lg">
                        <i class="fab fa-instagram"></i>
                    </div>
                    <div>
                        <p class="text-emerald-100/40 text-xs uppercase font-bold tracking-wider italic">Instagram</p>
                        <p class="text-white font-semibold">@@codewithmixx</p>
                    </div>
                </div>
                
                <div class="p-8 bg-white/5 backdrop-blur-sm rounded-3xl  mt-12">
                    <p class="text-emerald-100/70 text-sm leading-relaxed font-semibold">
                        Dostupan sam za konsultacije svakog radnog dana. Na poruke odgovaram u roku od 24h.
                    </p>
                </div>
            </div>

            <div class="lg:w-2/3 bg-emerald-800/70 backdrop-blur-md p-8 md:p-12 rounded-3xl  shadow-2xl">
                <form action="#" method="POST" class="space-y-6 flex flex-col">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label for="first-name" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Ime</label>
                            <input type="text" id="first-name" name="first-name" placeholder="Unesite ime" 
                                class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white placeholder:text-emerald-100/20 focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200">
                        </div>
                        <div class="space-y-2">
                            <label for="last-name" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Prezime</label>
                            <input type="text" id="last-name" name="last-name" placeholder="Unesite prezime" 
                                class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white placeholder:text-emerald-100/20 focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label for="phone" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Broj telefona</label>
                            <input type="tel" id="phone" name="phone" placeholder="+381 60 123 4567" 
                                class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white placeholder:text-emerald-100/20 focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200">
                        </div>
                        <div class="space-y-2">
                            <label for="email" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Email adresa</label>
                            <input type="email" id="email" name="email" placeholder="vas@email.com" 
                                class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white placeholder:text-emerald-100/20 focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="type" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Vrsta upita</label>
                        <select id="type" name="type" 
                            class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200 appearance-none">
                            <option value="individual" class="bg-emerald-900">Konsultacije za individualne časove</option>
                            <option value="exam-preparation" class="bg-emerald-900">Konsultacije za pripremanje ispita</option>
                            <option value="project-assignment" class="bg-emerald-900">Pomoć oko seminarskog</option>
                            <option value="cooperation" class="bg-emerald-900">Saradnja</option>
                            <option value="other" class="bg-emerald-900">Ostalo</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label for="message" class="text-sm font-semibold text-emerald-100/60 ml-1 ">Poruka</label>
                        <textarea id="message" name="message" rows="5" placeholder="Vaša poruka..." 
                            class="w-full bg-emerald-950/50  rounded-xl px-4 py-3 text-white placeholder:text-emerald-100/20 focus:outline-hidden focus:ring-2 focus:ring-emerald-500/40 transition duration-200 resize-none h-32"></textarea>
                    </div>

                    <button type="submit" 
                        class="px-6 mx-auto py-4 bg-amber-500 hover:bg-amber-400 text-slate-800 font-bold rounded-2xl shadow-lg transition duration-200 active:scale-95 cursor-pointer">
                        Pošalji poruku
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>
