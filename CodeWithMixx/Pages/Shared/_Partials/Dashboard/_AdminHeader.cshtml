<header class="flex items-center justify-end bg-emerald-900/80 px-8 py-4 backdrop-blur-3xl shadow-md border-b border-emerald-800/50 w-full text-white">
    
    <button id="sidebar-toggle"
            aria-label="Otvori meni"
            aria-expanded="false"
            aria-controls="mobile-sidebar"
            class="md:hidden mr-auto flex items-center justify-center w-10 h-10 rounded-lg text-emerald-300 hover:text-amber-400 hover:bg-emerald-800 active:scale-95 transition-all duration-150">
        <i class="fas fa-bars text-xl"></i>
    </button>

    <div class="flex items-center space-x-4">
        <a  hx-get="/admin/dashboard"
            hx-swap="innerHTML"
            hx-target="#content"
            class="flex items-center space-x-3 hover:text-amber-500 transition-colors group">
            <span class="font-semibold text-amber-100 hidden md:block">Administrator</span>
            <div class="w-10 h-10 rounded-full bg-emerald-700 flex items-center justify-center border-2 border-emerald-600 group-hover:border-amber-600 group-active:border-amber-600 transition-all duration-200 overflow-hidden">
                <i class="fas fa-user text-emerald-300"></i>
            </div>
        </a>
    </div>
</header>
