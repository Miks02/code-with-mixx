@page
@model IndexModel

@{
    Layout = "_Layout";
}

<section id="vanta-bg" class="bg-linear-to-br from-emerald-800 to-emerald-900 h-screen w-full flex flex-col justify-center items-center px-4 shadow-2xl">
    <div class="w-full max-w-md bg-emerald-300/10 backdrop-blur-md rounded-2xl p-8 shadow-2xl">
        <div class="text-center mb-10">
            <h2 class="text-4xl font-bold text-white mb-2">Pristup nalogu</h2>
            <p class="text-emerald-100/80">Spreman/a da rešiš sve ispitne probleme ?</p>
        </div>

        <form id="login-form" method="post" class="flex flex-col gap-4">
            <div asp-validation-summary="ModelOnly" class="text-amber-600 font-semibold text-sm"></div>
            
            <div>
                <label asp-for="LoginVm.Email" class="text-sm font-semibold text-emerald-100/60 ml-1">Email adresa</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input id="login-email" asp-for="LoginVm.Email" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="pera@email.com" />
                </div>
                <div id="email-validation" class="text-amber-600 font-semibold text-xs ml-1">
                    <span  asp-validation-for="LoginVm.Email"></span>
                </div>
            </div>

            <div>
                <label asp-for="LoginVm.Password" class="text-sm font-semibold text-emerald-100/60 ml-1">Lozinka</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input id="login-password" asp-for="LoginVm.Password" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="••••••••" />
                </div>
                <div id="password-validation" class="text-amber-600 font-semibold text-xs ml-1">
                    <span  asp-validation-for="LoginVm.Password"></span>
                </div>
            </div>

            <div class="flex items-center justify-between px-1">
                <div class="flex items-center">
                    <input asp-for="LoginVm.RememberMe" 
                           class="checkbox-emerald" />
                    <label asp-for="LoginVm.RememberMe" class="ml-2 text-sm text-emerald-100 cursor-pointer select-none">Zapamti me</label>
                </div>
                <a href="#" class="text-sm text-emerald-100 hover:text-amber-300 transition-colors">Zaboravljena lozinka?</a>
            </div>

            <button id="login-btn" type="submit" 
                    class="py-4 bg-emerald-400 cursor-pointer text-emerald-900 font-bold text-lg rounded-xl hover:bg-emerald-300 transition duration-200 shadow-lg active:scale-[0.98]">
                Prijavi se
            </button>

            <div class="pt-4 border-t border-emerald-500/10 text-center">
                <p class="text-emerald-100 text-xs mb-1 font-semibold">Nemaš nalog?</p>
                <p class="text-emerald-100/80
 text-sm">
                    Pristup je omogućen isključivo učenicima i administratoru.
                </p>
            </div>
        </form>
    </div>
</section>
