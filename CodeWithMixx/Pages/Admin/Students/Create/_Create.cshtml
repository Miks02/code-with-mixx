@model StudentInput

<title hx-swap-oob="outerHTML">CodeWithMixx | Registracija Studenta</title>


<div class="max-w-4xl mx-auto">
    <div class="bg-emerald-300/10 backdrop-blur-md rounded-2xl p-8 shadow-2xl border border-emerald-500/10">
        <div class="mb-8">
            <h2 class="text-3xl font-bold text-white mb-2">Registracija Studenta</h2>
            <p class="text-emerald-100/60">Popunite podatke ispod kako biste kreirali novi studentski nalog.</p>
        </div>

        <form hx-post hx-target="#content" hx-swap="innerHTML" method="post" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div asp-validation-summary="ModelOnly" class="col-span-full text-amber-500 font-semibold text-sm bg-amber-500/10 p-3 rounded-lg border border-amber-500/20"></div>

            <div class="space-y-2">
                <label asp-for="FirstName" class="text-sm font-semibold text-emerald-100/60 ml-1">Ime</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-user"></i>
                    </span>
                    <input asp-for="FirstName" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="Marko" 
                    />
                </div>
                <span asp-validation-for="FirstName" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="LastName" class="text-sm font-semibold text-emerald-100/60 ml-1">Prezime</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-user"></i>
                    </span>
                    <input asp-for="LastName" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="Nikolić" 
                            />
                </div>
                <span asp-validation-for="LastName" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Email" class="text-sm font-semibold text-emerald-100/60 ml-1">Email adresa</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-envelope"></i>
                    </span>
                    <input asp-for="Email" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="marko@email.com" 
                            />
                </div>
                <span asp-validation-for="Email" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="PhoneNumber" class="text-sm font-semibold text-emerald-100/60 ml-1">Broj telefona</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-phone"></i>
                    </span>
                    <input asp-for="PhoneNumber" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="066111222" 
                            />
                </div>
                <span asp-validation-for="PhoneNumber" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="space-y-2 col-span-2">
                <label asp-for="University" class="text-sm font-semibold text-emerald-100/60 ml-1">Fakultet / Univerzitet</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-university"></i>
                    </span>
                    <input asp-for="University" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="Npr. ETF, FON, RAF..." 
                            />
                </div>
                <span asp-validation-for="University" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>


            <div class="space-y-2">
                <label asp-for="Password" class="text-sm font-semibold text-emerald-100/60 ml-1">Lozinka</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-lock"></i>
                    </span>
                    <input type="password" asp-for="Password" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="••••••••" 
                            />
                </div>
                <span asp-validation-for="Password" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="ConfirmPassword" class="text-sm font-semibold text-emerald-100/60 ml-1">Potvrdi lozinku</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-emerald-100/40">
                        <i class="fas fa-shield-alt"></i>
                    </span>
                    <input type="password" asp-for="ConfirmPassword" 
                           class="w-full pl-11 pr-4 py-3 bg-emerald-900/60 border border-emerald-500/20 rounded-xl text-white placeholder-emerald-100/20 focus:outline-none focus:ring-2 focus:ring-emerald-500/40 transition-all" 
                           placeholder="••••••••" 
                           />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-amber-500 font-semibold text-xs ml-1"></span>
            </div>

            <div class="col-span-full flex justify-center gap-4 mt-6">
                <button hx-get="/admin/students" 
                        hx-target="#content" 
                        hx-swap="innerHTML"
                        hx-push-url="true"
                        type="button" 
                        class="px-8 py-3 bg-emerald-900/40 text-emerald-100 font-semibold rounded-xl hover:bg-emerald-900/60 transition duration-200 border border-emerald-500/10">
                    Otkaži
                </button>
                <button type="submit" 
                        class="px-8 py-3 bg-emerald-400 text-emerald-900 font-bold rounded-xl hover:bg-emerald-300 transition duration-200 shadow-lg active:scale-[0.98]">
                    Kreiraj nalog
                </button>
            </div>
        </form>
    </div>
</div>
