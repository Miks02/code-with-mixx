@using CodeWithMixx.Domain.Entities.Classes
@using CodeWithMixx.Domain.Entities.Reservations
@model CodeWithMixx.Pages.Admin.Dashboard.DashboardViewModel;


<title hx-swap-oob="outerHTML">CodeWithMixx | Analitika</title>

    
@await Html.PartialAsync("_Partials/Dashboard/_PageHeading", ("Opšta statistika poslovanja", "Analitika"))

<div class="flex flex-wrap gap-4">

    <div class="group relative min-w-52 flex-1 overflow-hidden rounded-2xl bg-emerald-950/80 p-5 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-black/30">
        <div class="absolute inset-0 bg-linear-to-br from-emerald-500/10 to-transparent"></div>
        <div class="relative">
            <div class="mb-4 flex items-start justify-between">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-emerald-500/15 text-emerald-300">
                    <i class="fa-solid fa-coins text-lg"></i>
                </div>
                <span class="flex items-center gap-1 rounded-full bg-emerald-400/10 px-2.5 py-1 text-xs font-semibold text-emerald-300">
                    <i class="fa-solid fa-arrow-trend-up text-[10px]"></i>+12%
                </span>
            </div>
            <p class="text-2xl font-bold text-white">@Model.TotalIncome <span class="text-sm font-normal text-emerald-300/60">RSD</span></p>
            <p class="mt-1 text-sm text-emerald-300/70">Mesečni prihod</p>
        </div>
    </div>

    <div class="group relative min-w-52 flex-1 overflow-hidden rounded-2xl bg-sky-950/80 p-5 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-black/30">
        <div class="absolute inset-0 bg-linear-to-br from-sky-500/10 to-transparent"></div>
        <div class="relative">
            <div class="mb-4 flex items-start justify-between">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-sky-400/15 text-sky-300">
                    <i class="fa-solid fa-chalkboard-user text-lg"></i>
                </div>
                <span class="flex items-center gap-1 rounded-full bg-sky-400/10 px-2.5 py-1 text-xs font-semibold text-sky-300">
                    Ovaj mesec
                </span>
            </div>
            <p class="text-2xl font-bold text-white">@Model.CompletedClasses <span class="text-sm font-normal text-sky-300/60">časa</span></p>
            <p class="mt-1 text-sm text-sky-300/70">Održani časovi</p>
        </div>
    </div>

    <div class="group relative min-w-52 flex-1 overflow-hidden rounded-2xl bg-violet-950/80 p-5 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-black/30">
        <div class="absolute inset-0 bg-linear-to-br from-violet-500/10 to-transparent"></div>
        <div class="relative">
            <div class="mb-4 flex items-start justify-between">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-violet-400/15 text-violet-300">
                    <i class="fa-solid fa-user-graduate text-lg"></i>
                </div>
                <span class="flex items-center gap-1 rounded-full bg-violet-400/10 px-2.5 py-1 text-xs font-semibold text-violet-300">
                    <span class="relative flex h-2 w-2">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-violet-400 opacity-60"></span>
                        <span class="relative inline-flex h-2 w-2 rounded-full bg-violet-400"></span>
                    </span>
                    aktivni
                </span>
            </div>
            <p class="text-2xl font-bold text-white">@Model.ActiveStudents</p>
            <p class="mt-1 text-sm text-violet-300/70">Aktivni studenti</p>
        </div>
    </div>

    <div class="group relative min-w-52 flex-1 overflow-hidden rounded-2xl bg-amber-950/80 p-5 shadow-xl shadow-black/20 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-2xl hover:shadow-black/30">
        <div class="absolute inset-0 bg-linear-to-br from-amber-500/10 to-transparent"></div>
        <div class="relative">
            <div class="mb-4 flex items-start justify-between">
                <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-amber-400/15 text-amber-300">
                    <i class="fa-solid fa-file-contract text-lg"></i>
                </div>
                <span class="flex items-center gap-1 rounded-full bg-amber-400/10 px-2.5 py-1 text-xs font-semibold text-amber-300">Projekti
                </span>
            </div>
            <p class="text-2xl font-bold text-white">@Model.ProjectsCount <span class="ml-1 text-xs font-normal text-amber-300/70">u toku</span></p>
            <p class="mt-1 text-sm text-amber-300/70">Seminarski radovi</p>
        </div>
    </div>

</div>

<div class="flex flex-col gap-4 xl:flex-row">

    <div class="min-w-0 flex-3 rounded-2xl bg-emerald-950/40 p-6 shadow-xl shadow-black/20 backdrop-blur-sm">
        <div class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <div>
                <h3 class="font-semibold text-white">Analiza prihoda i broja učenika</h3>
                <p class="mt-0.5 text-xs text-amber-300/90">Stopa rasta učenika i profita na mesečnom nivou</p>
            </div>
            <div class="flex gap-1.5">
                <select class="bg-amber-400 px-2 py-1 rounded-md shadow-md font-semibold text-sky-900">
                    <option selected disabled hidden value="2026">2026</option>
                </select>
            </div>
        </div>
        <div class="flex h-56 flex-col items-center justify-center rounded-xl bg-green-900/30 shadow-sm">
            <canvas id="finance-chart"></canvas>
        </div>
    </div>

    <div class="min-w-0 flex-2 rounded-2xl bg-indigo-700/40 p-6 shadow-xl shadow-black/20 backdrop-blur-sm">
        <div class="mb-5">
            <h3 class="font-semibold text-white">Grafikon broja časova</h3>
            <p class="mt-0.5 text-xs text-emerald-300/60">Naziv časa - broj održanih</p>
        </div>
        <div class="flex h-56 flex-col items-center justify-center rounded-xl bg-indigo-900/25 shadow-sm p-4">
            <canvas id="subjects-chart"></canvas>
        </div>
    </div>

    <div class="flex min-w-60 flex-1 flex-col rounded-2xl bg-green-900/80 p-6 shadow-xl shadow-black/20 backdrop-blur-sm">
        <div class="mb-5">
            <h3 class="font-semibold text-white">Brze akcije</h3>
            <p class="mt-0.5 text-xs text-amber-300/90">Prečice za česte operacije</p>
        </div>
        <div class="flex flex-1 flex-col gap-2.5">

            <button 
                hx-get="/admin/students/create"
                hx-target="#content"
                hx-push-url="true"
                hx-swap="innerHTML"
                class="flex w-full items-center gap-3 rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-emerald-900/50 transition-all duration-200 hover:bg-emerald-500 active:scale-[.98]">
                <i class="fa-solid fa-user-plus w-4 text-center"></i>
                Dodaj studenta
            </button>

            <button 
                hx-get="/admin/classes/create"
                hx-target="#content"
                hx-push-url="true"
                hx-swap="innerHTML"
                class="flex w-full items-center gap-3 rounded-xl bg-white/8 px-4 py-3 text-sm font-medium text-emerald-100 transition-all duration-200 hover:bg-white/12 active:scale-[.98]">
                <i class="fa-solid fa-calendar-plus w-4 text-center text-emerald-400"></i>
                Zakaži čas
            </button>

            <button 
                disabled
                class="flex w-full items-center gap-3 rounded-xl disabled:pointer-events-none disabled:opacity-50 bg-white/8 px-4 py-3 text-sm font-medium text-emerald-100 transition-all duration-200 hover:bg-white/12 active:scale-[.98]">
                <i class="fa-solid fa-plus w-4 text-center text-emerald-400"></i>
                Novi projekat
            </button>

            <button 
                disabled
                class="flex w-full items-center gap-3 disabled:pointer-events-none disabled:opacity-50  rounded-xl bg-white/8 px-4 py-3 text-sm font-medium text-emerald-100 transition-all duration-200 hover:bg-white/12 active:scale-[.98]">
                <i class="fa-solid fa-chart-column w-4 text-center text-emerald-400"></i>
                Pregled prihoda
            </button>

            <button 
                disabled
                class="flex w-full items-center gap-3 disabled:pointer-events-none disabled:opacity-50  rounded-xl bg-white/8 px-4 py-3 text-sm font-medium text-emerald-100 transition-all duration-200 hover:bg-white/12 active:scale-[.98]">
                <i class="fa-solid fa-gear w-4 text-center text-emerald-400"></i>
                Podešavanja
            </button>

        </div>
    </div>

</div>


    <div class="w-full min-w-0 max-w-full overflow-hidden rounded-2xl bg-emerald-950/80 shadow-xl shadow-black/20">

        <div class="flex flex-col gap-3 px-5 pb-4 pt-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
            <div>
                <h3 class="font-semibold text-white">Top 6 predstojećih časova</h3>
                <p class="mt-0.5 text-xs text-emerald-300/60">Najbliži zakazani termini</p>
            </div>
            <button 
                hx-get="/admin/classes"
                hx-target="#content"
                hx-push-url="true"
                hx-swap="innerHTML"
                class="self-start text-sm font-medium text-emerald-400 transition-colors hover:text-amber-300 sm:self-auto">
                Vidi sve <i class="fa-solid fa-arrow-right ml-1 text-xs"></i>
            </button>
        </div>

        @if (!Model.UpcomingTerms.Any())
        {
            <div class="flex flex-col items-center justify-center gap-2 px-6 py-12 text-center">
                <i class="fa-solid fa-calendar-xmark text-3xl text-emerald-700"></i>
                <p class="text-sm font-medium text-emerald-300/60">Trenutno nema predstojećih časova za pregled</p>
            </div>
        }

        <div class="grid grid-cols-1 gap-4 p-5 sm:p-6 lg:grid-cols-3">
            @foreach (var classItem in Model.UpcomingTerms)
            {
                <article
                    hx-get="/admin/classes/index?&reservationId=@classItem.Id"
                    hx-target="#content"
                    hx-push-url="true"
                    hx-swap="innerHTML"
                    hx-indicator="#list-indicator"
                    hx-include="[name='subjectId'], [name='sort'], [name='filter'], [name='page']"
                    class="rounded-xl bg-white/5 p-4 shadow-md hover:bg-white/10 cursor-pointer active:scale-95 active:opacity-70 transition-all duration-100 flex flex-col justify-between">
                    <div class="mb-3 flex justify-between gap-3 items-start ">
                        <div>
                            <h4 class="font-semibold text-white md:w-50">@classItem.SubjectName</h4>
                            <p class="text-xs text-emerald-300/70">@classItem.StudentName</p>
                        </div>
                        <div class="flex justify-end flex-wrap md:flex-nowrap gap-2 items-center font-semibold text-sm">

                            @switch (classItem.PaymentStatus)
                            {
                                case PaymentStatus.Pending:
                                    <p class="text-amber-200 sm:bg-amber-900 sm:px-2 sm:py-1 sm:rounded-md sm:shadow-sm font-semibold"><i class="fa-solid fa-warning mr-2"></i>Neplaćeno</p>
                                    break;
                                case PaymentStatus.Paid:
                                    <p class="text-sky-200 sm:bg-sky-900 sm:px-2 sm:py-1 sm:rounded-md sm:shadow-sm font-semibold"><i class="fa-solid fa-circle-check mr-2"></i>Plaćeno</p>
                                    break;
                                case PaymentStatus.Overdue:
                                    <p class="text-red-200 sm:bg-red-900 sm:px-2 sm:py-1 sm:rounded-md sm:shadow-sm font-semibold"><i class="fa-solid fa-circle-exclamation mr-2"></i>Dugovanje</p>
                                    break;
                                case PaymentStatus.PartiallyPaid:
                                    <p class="text-yellow-200 sm:bg-yellow-900 px-2 sm:py-1 sm:rounded-md sm:shadow-sm font-semibold w-20 md:w-auto"><i class="fa-solid fa-circle-half-stroke mr-2"></i>Del. plaćeno</p>
                                    break;
                            }
                        </div>
                    </div>
                    <div class="flex justify-between items-center gap-2 flex-wrap text-sm text-emerald-100/80">
                        <div class="flex flex-col gap-2">

                            <p class="sm:p-2 sm:bg-emerald-900 sm:rounded-md sm:shadow-sm"><i class="fa-solid fa-chalkboard-user mr-2 text-emerald-400/80"></i>Časovi: @classItem.AmountOfClasses</p>
                            <p class="sm:p-2 sm:bg-emerald-900 sm:rounded-md sm:shadow-sm"><i class="fa-solid fa-money-bill mr-2 text-emerald-400/80"></i>Cena: @classItem.TotalPrice</p>
                        </div>
                        <div class="flex flex-col gap-2">
                            <p class="sm:p-2 sm:bg-emerald-900 sm:rounded-md sm:shadow-sm"><i class="fa-solid fa-hourglass-start mr-2 text-emerald-400/80"></i>@classItem.StartsAt</p>
                            <p class="sm:p-2 sm:bg-emerald-900 sm:rounded-md sm:shadow-sm"><i class="fa-solid fa-hourglass-end mr-2 text-emerald-400/80"></i>@classItem.EndsAt</p>
                        </div>
                    </div>
                </article>
            }
        </div>
        </div>
        